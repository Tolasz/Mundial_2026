{
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "chat.tools.terminal.autoApprove": {
    "/^git add src/lib/actions/champion\\.ts src/app/\\(app\\)/champion/page\\.tsx src/app/\\(app\\)/champion/ChampionPicker\\.tsx ; git commit -m \"T11: typ mistrza \\+ bonus 50\"$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^git add -A ; git commit -m \"T11: typ mistrza \\+ bonus 50\"$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
